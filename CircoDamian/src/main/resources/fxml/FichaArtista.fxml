<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxWidth="900" maxHeight="620" minWidth="900" minHeight="620"
            prefWidth="900" prefHeight="620"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.FichaArtistaController">
  <top>
    <VBox styleClass="background" spacing="4">
      <padding><Insets top="14" left="24" bottom="12" right="24"/></padding>
      <Label text="Mi Ficha en el Circo" textFill="WHITE"><font><Font size="17"/></font></Label>
      <Label text="Tus datos personales, profesionales y trayectoria"
             textFill="#aaaaaa" style="-fx-font-size:11;"/>
    </VBox>
  </top>
  <center>
    <VBox spacing="0">
      <!-- Datos en dos columnas fijas -->
      <GridPane hgap="16" vgap="10" style="-fx-padding:20 30 10 30;">
        <columnConstraints>
          <ColumnConstraints minWidth="120" maxWidth="140"/>
          <ColumnConstraints hgrow="ALWAYS"/>
          <ColumnConstraints minWidth="120" maxWidth="140"/>
          <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Nombre:"        style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="lblNombre"     GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Email:"         style="-fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Label fx:id="lblEmail"      GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="Nacionalidad:"  style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="lblNacionalidad" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Apodo:"         style="-fx-font-weight:bold;" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Label fx:id="lblApodo"      GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Label text="Especialidades:" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="lblEspecialidades" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"
               GridPane.columnSpan="3"/>
      </GridPane>

      <Separator style="-fx-padding:0 30 0 30;"/>

      <VBox spacing="6" VBox.vgrow="ALWAYS" style="-fx-padding:10 30 10 30;">
        <Label text="Trayectoria en el circo:"
               style="-fx-font-weight:bold; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
        <TextArea fx:id="taTrayectoria" editable="false" wrapText="true"
                  VBox.vgrow="ALWAYS" prefHeight="340"
                  style="-fx-font-family:'Courier New'; -fx-font-size:12;"/>
      </VBox>
    </VBox>
  </center>
  <bottom>
    <HBox alignment="CENTER_RIGHT" spacing="10">
      <padding><Insets bottom="10" right="16" top="8"/></padding>
      <Button text="Volver" onAction="#volver" prefWidth="100" prefHeight="30"/>
      <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda"
              prefWidth="34" prefHeight="34" accessibleText="Ayuda"/>
    </HBox>
  </bottom>
</BorderPane>
