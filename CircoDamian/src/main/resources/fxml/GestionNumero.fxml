<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane
            prefWidth="1120" prefHeight="760"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.GestionNumeroController">

  <top>
    <VBox styleClass="background" spacing="4">
      <padding><Insets top="14" left="24" bottom="12" right="24"/></padding>
      <Label text="Gestión de Números Circenses" textFill="WHITE"><font><Font size="18"/></font></Label>
      <Label text="Crea, modifica o elimina números. Solo se pueden eliminar si no están asignados a ningún espectáculo."
             textFill="#aaaaaa" style="-fx-font-size:12;" wrapText="true"/>
    </VBox>
  </top>

  <center>
    <SplitPane dividerPositions="0.55">

      <!-- ==== IZQUIERDA: formulario del número ==== -->
      <VBox spacing="12" style="-fx-padding:20;">
        <Label fx:id="lblTitulo" text="Crear nuevo número"
               style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
        <Separator/>

        <!-- Selector de número existente -->
        <Label text="Selecciona número para modificar o eliminar:"
               style="-fx-font-size:12;"/>
        <ComboBox fx:id="cbNumero" maxWidth="Infinity" prefHeight="34"
                  promptText="-- O selecciona uno existente --"/>

        <Separator/>

        <!-- Nombre y duración en grid -->
        <GridPane hgap="14" vgap="8">
          <columnConstraints>
            <ColumnConstraints percentWidth="65"/>
            <ColumnConstraints percentWidth="35"/>
          </columnConstraints>

          <Label text="Nombre del número:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
          <Label text="Duración (x,0 o x,5):" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
          <TextField fx:id="txtNombre" promptText="Ej: Apertura Acrobática"
                     maxWidth="Infinity" prefHeight="34"
                     GridPane.columnIndex="0" GridPane.rowIndex="1"/>
          <TextField fx:id="txtDuracion" promptText="Ej: 8,5"
                     maxWidth="Infinity" prefHeight="34"
                     GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <Separator/>

        <Label text="Artistas asignados al número:" style="-fx-font-weight:bold;"/>
        <TableView fx:id="tablaArtistasAsignados" prefHeight="180" VBox.vgrow="SOMETIMES">
          <columns>
            <TableColumn fx:id="colNombreArtista" text="Artista"        prefWidth="200" minWidth="140"/>
            <TableColumn fx:id="colEspecArtista"  text="Especialidades" prefWidth="320" minWidth="200"/>
          </columns>
          <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
          </columnResizePolicy>
        </TableView>

        <Label fx:id="lblMensaje" text="" wrapText="true" maxWidth="Infinity"
               style="-fx-font-size:12;"/>

        <HBox spacing="12" alignment="CENTER_LEFT">
          <Button fx:id="btnNuevo"    text="Nuevo"    onAction="#nuevo"
                  prefHeight="36" prefWidth="100"/>
          <Button fx:id="btnGuardar"  text="Guardar"  onAction="#guardar"
                  prefHeight="36" prefWidth="120" styleClass="btnGreen"
                  style="-fx-font-weight:bold;"/>
          <Button fx:id="btnEliminar" text="Eliminar" onAction="#eliminar"
                  prefHeight="36" prefWidth="120" disable="true"
                  style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;"/>
        </HBox>
      </VBox>

      <!-- ==== DERECHA: lista de artistas disponibles ==== -->
      <VBox spacing="10" style="-fx-padding:18;">
        <Label text="Artistas disponibles" style="-fx-font-weight:bold; -fx-font-size:13;"/>
        <Label text="Ctrl+clic para selección múltiple."
               style="-fx-font-size:11; -fx-text-fill:#666;"/>
        <Label text="Al marcar/desmarcar aquí, configuras qué artistas tendrá el número al guardar."
               style="-fx-font-size:11; -fx-text-fill:#888;" wrapText="true"/>
        <ListView fx:id="listArtistas" VBox.vgrow="ALWAYS"/>
      </VBox>

    </SplitPane>
  </center>

  <bottom>
    <HBox alignment="CENTER_RIGHT" spacing="12">
      <padding><Insets bottom="14" right="24" top="12" left="24"/></padding>
      <Button text="Volver al menú" onAction="#volver"
              prefWidth="140" prefHeight="36"/>
      <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda"
              prefWidth="36" prefHeight="36" accessibleText="Ayuda"/>
    </HBox>
  </bottom>
</BorderPane>
