<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefWidth="1120" prefHeight="760"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.BuscarEspectaculoController">
  <top>
    <VBox style="-fx-background-color:#1a1a2e; -fx-padding:12 20 12 20;">
      <Label text="Buscar Espectaculo" textFill="WHITE"><font><Font size="20"/></font></Label>
      <Label text="Consulta la informacion completa de cualquier espectaculo"
             textFill="#aaaaaa" style="-fx-font-size:11;"/>
    </VBox>
  </top>
  <center>
    <VBox spacing="14" style="-fx-padding:22;">

      <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Selecciona un espectaculo:"
               style="-fx-font-weight:bold; -fx-font-size:13;"/>
        <ComboBox fx:id="cbEspectaculo" prefWidth="560" prefHeight="34"
                  promptText="-- Selecciona un espectaculo --"/>
      </HBox>

      <Label fx:id="lblSinSeleccion"
             text="Selecciona un espectaculo del desplegable para ver su informacion completa."
             style="-fx-text-fill:#888; -fx-font-size:13;" wrapText="true"/>

      <VBox fx:id="panelCompleto" spacing="10">
        <Separator/>
        <Label text="Datos del espectaculo"
               style="-fx-font-weight:bold; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
        <GridPane hgap="16" vgap="7">
          <Label text="ID:"          style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
          <Label fx:id="lblId"                                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>
          <Label text="Nombre:"      style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
          <Label fx:id="lblNombre"   style="-fx-font-size:14;"     GridPane.columnIndex="1" GridPane.rowIndex="1"/>
          <Label text="Periodo:"     style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
          <Label fx:id="lblPeriodo"                                 GridPane.columnIndex="1" GridPane.rowIndex="2"/>
          <Label text="Coordinador:" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
          <Label fx:id="lblCoordinador" wrapText="true" maxWidth="500"
                                                                    GridPane.columnIndex="1" GridPane.rowIndex="3"/>
          <Label text=""             style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
          <Label fx:id="lblSenior"                                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        </GridPane>

        <Separator/>
        <Label text="Numeros del espectaculo (con artistas):"
               style="-fx-font-weight:bold; -fx-font-size:13;"/>
        <TextArea fx:id="taNumeros" editable="false" wrapText="true"
                  prefHeight="270" VBox.vgrow="ALWAYS"
                  style="-fx-font-family:'Courier New'; -fx-font-size:12;"/>
      </VBox>

    </VBox>
  </center>
  <bottom>
    <HBox alignment="CENTER_RIGHT" spacing="8">
      <padding><Insets bottom="14" right="24" top="12" left="24"/></padding>
      <Button text="Volver" onAction="#volver" prefWidth="110" prefHeight="36"/>
      <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda"
              prefWidth="34" prefHeight="34" accessibleText="Ayuda"/>
    </HBox>
  </bottom>
</BorderPane>
