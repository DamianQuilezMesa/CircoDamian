<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefWidth="900" prefHeight="620"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.VerEspectaculosController">
  <top>
    <VBox style="-fx-background-color:#1a1a2e; -fx-padding:12 20 12 20;">
      <Label text="Espectaculos del Circo" textFill="WHITE"><font><Font size="20"/></font></Label>
      <Label text="Selecciona un espectaculo para ver su informacion"
             textFill="#aaaaaa" style="-fx-font-size:11;"/>
    </VBox>
  </top>
  <center>
    <VBox spacing="12" style="-fx-padding:20;">

      <!-- Selector -->
      <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Espectaculo:" style="-fx-font-weight:bold; -fx-font-size:13;"/>
        <ComboBox fx:id="cbEspectaculo" prefWidth="560" prefHeight="34"
                  promptText="-- Selecciona un espectaculo --"/>
      </HBox>

      <!-- Mensaje cuando no hay selección -->
      <Label fx:id="lblSinSeleccion"
             text="Selecciona un espectaculo del desplegable para ver su informacion."
             style="-fx-text-fill:#888; -fx-font-size:13;" wrapText="true"/>

      <!-- Panel de detalle (oculto hasta selección) -->
      <VBox fx:id="panelDetallCompleto" spacing="10">

        <Separator/>

        <!-- Datos básicos (siempre, CU1) -->
        <Label text="Informacion basica" style="-fx-font-weight:bold; -fx-font-size:13;
               -fx-text-fill:#1a1a2e;"/>
        <GridPane hgap="16" vgap="6">
          <Label text="ID:" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
          <Label fx:id="lblId" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
          <Label text="Nombre:" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
          <Label fx:id="lblNombre" style="-fx-font-size:14;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
          <Label text="Periodo:" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
          <Label fx:id="lblPeriodo" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>

        <Separator/>

        <!-- Datos completos (solo autenticados, CU4) -->
        <Label text="Informacion completa (requiere sesion iniciada)"
               style="-fx-font-weight:bold; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
        <GridPane hgap="16" vgap="6">
          <Label text="Coordinador:" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
          <Label fx:id="lblCoordinador" wrapText="true" maxWidth="500"
                 GridPane.columnIndex="1" GridPane.rowIndex="0"/>
          <Label text="" style="-fx-font-weight:bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
          <Label fx:id="lblSenior" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <Label text="Numeros y artistas (ordenados):" style="-fx-font-weight:bold;"/>
        <TextArea fx:id="taNumeros" editable="false" wrapText="true"
                  prefHeight="240" VBox.vgrow="ALWAYS"
                  style="-fx-font-family:'Courier New'; -fx-font-size:12;"/>
      </VBox>

    </VBox>
  </center>
  <bottom>
    <HBox alignment="CENTER_RIGHT" spacing="8">
      <padding><Insets bottom="10" right="15" top="6"/></padding>
      <Button text="Volver" onAction="#volver" prefWidth="100" prefHeight="30"/>
      <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda"
              prefWidth="34" prefHeight="34" accessibleText="Ayuda"/>
    </HBox>
  </bottom>
</BorderPane>
