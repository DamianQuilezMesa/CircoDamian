<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxWidth="900" maxHeight="620" minWidth="900" minHeight="620"
            prefWidth="900" prefHeight="620"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.LoginController">
  <top>
    <VBox styleClass="background" alignment="CENTER" spacing="6">
      <padding><Insets top="30" bottom="20" left="40" right="40"/></padding>
      <Label text="CIRCO" style="-fx-font-size:28; -fx-font-weight:bold;" textFill="WHITE"/>
      <Label text="Sistema de Gestion Circense" textFill="#aaaaaa" style="-fx-font-size:13;"/>
    </VBox>
  </top>
  <center>
    <VBox alignment="CENTER" spacing="16" maxWidth="420">
      <padding><Insets top="20" left="60" right="60" bottom="20"/></padding>
      <Label text="Inicio de Sesion" style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
      <Separator/>
      <VBox spacing="8">
        <Label text="Nombre de usuario:"/>
        <TextField fx:id="txtUsuario" promptText="usuario" prefHeight="36" maxWidth="Infinity"/>
        <Label text="Contrasena:"/>
        <PasswordField fx:id="pfPassword" promptText="contrasena" prefHeight="36" maxWidth="Infinity"/>
        <TextField fx:id="tfPasswordVisible" promptText="contrasena" prefHeight="36"
                   maxWidth="Infinity" visible="false"/>
        <CheckBox fx:id="chkMostrarPassword" onAction="#toggleMostrarPassword"
                  text="Mostrar contrasena"/>
      </VBox>
      <Label fx:id="lblMensaje" text="" style="-fx-text-fill:red;" wrapText="true"/>
      <HBox alignment="CENTER" spacing="12">
        <Button onAction="#login" prefHeight="36" prefWidth="150"
                styleClass="btnGreen" text="Entrar" style="-fx-font-size:14;"/>
        <Button onAction="#recuperarPassword" prefHeight="36" prefWidth="180"
                text="Recuperar contrasena"/>
      </HBox>
      <HBox alignment="CENTER_RIGHT">
        <Button text="Volver" onAction="#volverBienvenida" prefWidth="90" prefHeight="30"/>
        <Region HBox.hgrow="NEVER" minWidth="8"/>
        <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda"
                prefWidth="34" prefHeight="34" accessibleText="Ayuda"/>
      </HBox>
    </VBox>
  </center>
</BorderPane>
