<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane
            prefWidth="1120" prefHeight="760"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.GestionEspectaculoController">

  <top>
    <VBox styleClass="background" spacing="4">
      <padding><Insets top="14" left="24" bottom="12" right="24"/></padding>
      <Label text="Gestión de Espectáculos" textFill="WHITE"><font><Font size="18"/></font></Label>
      <Label text="Crea, modifica o elimina espectáculos. Los números se gestionan en su propia pantalla."
             textFill="#aaaaaa" style="-fx-font-size:12;" wrapText="true"/>
    </VBox>
  </top>

  <center>
    <SplitPane dividerPositions="0.28">

      <!-- ==== IZQUIERDA: selector y acciones ==== -->
      <VBox spacing="10" style="-fx-padding:14; -fx-background-color:#f5f5f5;" minWidth="280">
        <Label text="Espectáculos existentes:" style="-fx-font-weight:bold;"/>
        <ComboBox fx:id="cbEspectaculo" maxWidth="Infinity" prefHeight="34"
                  promptText="-- Selecciona para editar/eliminar --"/>
        <Button text="+ Nuevo espectáculo" onAction="#nuevoEspectaculo"
                maxWidth="Infinity" prefHeight="34"
                style="-fx-font-weight:bold;"/>
        <Button text="Eliminar seleccionado" onAction="#eliminarEspectaculo"
                maxWidth="Infinity" prefHeight="34"
                style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;"/>
        <Separator/>
        <Button text="Ir a Gestionar Números" onAction="#irGestionNumeros"
                maxWidth="Infinity" prefHeight="34"
                style="-fx-background-color:#2980b9;-fx-text-fill:white;-fx-font-weight:bold;"/>
        <Label fx:id="lblMensaje" text="" wrapText="true" maxWidth="Infinity"
               style="-fx-font-size:12; -fx-padding:8 0 0 0;"/>
      </VBox>

      <!-- ==== DERECHA: wizard de 2 pasos ==== -->
      <VBox spacing="0">

        <!-- ========== PASO 1: datos del espectáculo ========== -->
        <VBox fx:id="panelPaso1" spacing="12" style="-fx-padding:20;">
          <Label text="PASO 1 — Datos del espectáculo"
                 style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
          <Separator/>

          <GridPane hgap="18" vgap="10" maxWidth="Infinity">
            <columnConstraints>
              <ColumnConstraints percentWidth="50"/>
              <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <Label text="Nombre (máx. 25 caracteres):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label text="Coordinador:"                  GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <TextField fx:id="txtNombreEsp" promptText="Nombre del espectáculo"
                       prefHeight="34" maxWidth="Infinity"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cbCoordinador" prefHeight="34" maxWidth="Infinity"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Fecha inicio:"             GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label text="Fecha fin (máx. 1 año):"  GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <DatePicker fx:id="dpInicio" prefHeight="34" maxWidth="Infinity"
                        GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <DatePicker fx:id="dpFin"    prefHeight="34" maxWidth="Infinity"
                        GridPane.columnIndex="1" GridPane.rowIndex="3"/>
          </GridPane>

          <Separator/>
          <HBox spacing="14" alignment="CENTER_LEFT">
            <Button text="Siguiente →" onAction="#siguiente"
                    prefWidth="150" prefHeight="38" styleClass="btnGreen"
                    style="-fx-font-size:13; -fx-font-weight:bold;"/>
            <Label text="El espectáculo no se guarda hasta completar los números del Paso 2."
                   style="-fx-font-size:11; -fx-text-fill:#888;" wrapText="true" maxWidth="400"/>
          </HBox>
        </VBox>

        <!-- ========== PASO 2: asignar números ========== -->
        <VBox fx:id="panelPaso2" spacing="12" style="-fx-padding:20;"
              visible="false" managed="false">

          <Label fx:id="lblEspActual" text=""
                 style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
          <Label fx:id="lblContador" text=""
                 style="-fx-font-weight:bold; -fx-text-fill:#e67e22; -fx-font-size:12;"/>
          <Separator/>

          <!-- ===== Añadir número: cuadro destacado ===== -->
          <VBox spacing="10" style="-fx-background-color:#eef4fb; -fx-background-radius:6; -fx-padding:12; -fx-border-color:#c9dff3; -fx-border-radius:6;">
            <Label text="Añadir número al espectáculo" style="-fx-font-weight:bold; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>

            <GridPane hgap="14" vgap="6">
              <columnConstraints>
                <ColumnConstraints percentWidth="70"/>
                <ColumnConstraints percentWidth="15" minWidth="80"/>
                <ColumnConstraints percentWidth="15" minWidth="110"/>
              </columnConstraints>

              <!-- Fila 0: etiquetas -->
              <Label text="Número a añadir:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                     style="-fx-font-size:11; -fx-text-fill:#555;"/>
              <Label text="Orden:"            GridPane.columnIndex="1" GridPane.rowIndex="0"
                     style="-fx-font-size:11; -fx-text-fill:#555;"/>

              <!-- Fila 1: controles -->
              <ComboBox fx:id="cbNumero" prefHeight="36" maxWidth="Infinity"
                        GridPane.columnIndex="0" GridPane.rowIndex="1"/>
              <TextField fx:id="txtOrden" promptText="1" prefHeight="36" maxWidth="Infinity"
                         GridPane.columnIndex="1" GridPane.rowIndex="1"/>
              <Button fx:id="btnAnadir" text="+ Añadir" onAction="#anadirNumero"
                      prefHeight="36" maxWidth="Infinity" styleClass="btnGreen"
                      style="-fx-font-weight:bold;"
                      GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            </GridPane>
          </VBox>

          <!-- ===== Tabla de números del espectáculo ===== -->
          <Label text="Números asignados (mínimo 3):" style="-fx-font-weight:bold;"/>
          <TableView fx:id="tablaAsignados" VBox.vgrow="ALWAYS" prefHeight="260">
            <columns>
              <TableColumn fx:id="colOrden"    text="#"        prefWidth="50"  minWidth="40"/>
              <TableColumn fx:id="colNombre"   text="Número"   prefWidth="220" minWidth="160"/>
              <TableColumn fx:id="colDuracion" text="Duración" prefWidth="100" minWidth="80"/>
              <TableColumn fx:id="colArtistas" text="Artistas" prefWidth="350" minWidth="200"/>
            </columns>
            <columnResizePolicy>
              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
          </TableView>

          <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="btnQuitar" text="− Quitar seleccionado" onAction="#quitarNumero"
                    prefHeight="32" prefWidth="190"
                    style="-fx-background-color:#e74c3c;-fx-text-fill:white;-fx-font-weight:bold;"/>
          </HBox>

          <Separator/>
          <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="← Volver al Paso 1" onAction="#volverPaso1"
                    prefHeight="36" prefWidth="160"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnGuardar" text="✓ Guardar espectáculo" onAction="#guardar"
                    prefHeight="36" prefWidth="210" styleClass="btnGreen"
                    style="-fx-font-size:13; -fx-font-weight:bold;" disable="true"/>
          </HBox>
        </VBox>

      </VBox>
    </SplitPane>
  </center>

  <bottom>
    <HBox alignment="CENTER_RIGHT" spacing="12">
      <padding><Insets bottom="14" right="24" top="12" left="24"/></padding>
      <Button text="Volver al menú" onAction="#volver"
              prefWidth="140" prefHeight="36"/>
      <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda"
              prefWidth="36" prefHeight="36" accessibleText="Ayuda"/>
    </HBox>
  </bottom>
</BorderPane>
