<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxWidth="900" maxHeight="620" minWidth="900" minHeight="620"
            prefWidth="900" prefHeight="620"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.damianqm.tarea3adt.controller.ModificarPersonaController">
  <top>
    <VBox styleClass="background" spacing="4">
      <padding><Insets top="14" left="24" bottom="12" right="24"/></padding>
      <Label text="Modificar Persona" textFill="WHITE"><font><Font size="17"/></font></Label>
      <Label text="Solo el Administrador puede modificar datos de personas"
             textFill="#aaaaaa" style="-fx-font-size:11;"/>
    </VBox>
  </top>
  <center>
    <ScrollPane fitToWidth="true" fitToHeight="false"
                style="-fx-background-color:transparent;" hbarPolicy="NEVER">
      <VBox spacing="9" maxWidth="860">
        <padding><Insets top="14" left="30" right="30" bottom="14"/></padding>

        <!-- Selector persona -->
        <Label text="SELECCIONA UNA PERSONA" style="-fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
        <ComboBox fx:id="cbPersona" prefHeight="34" maxWidth="Infinity"
                  promptText="-- Selecciona una persona --"/>
        <Label fx:id="lblPerfil" text="" style="-fx-font-style:italic; -fx-text-fill:#555;"/>

        <Separator/>

        <!-- Datos personales -->
        <Label text="DATOS PERSONALES" style="-fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
        <GridPane hgap="14" vgap="8" maxWidth="Infinity">
          <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
          </columnConstraints>
          <Label text="Nombre completo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
          <Label text="Email:"           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
          <TextField fx:id="txtNombre" promptText="Nombre y apellidos"
                     prefHeight="32" maxWidth="Infinity"
                     GridPane.columnIndex="0" GridPane.rowIndex="1"/>
          <TextField fx:id="txtEmail"  promptText="nombre@dominio.com"
                     prefHeight="32" maxWidth="Infinity"
                     GridPane.columnIndex="1" GridPane.rowIndex="1"/>
          <Label text="Nacionalidad:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                 GridPane.columnSpan="2"/>
          <ComboBox fx:id="cbNacionalidad" prefHeight="32" maxWidth="Infinity"
                    promptText="-- Selecciona un pais --" editable="false"
                    GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2"/>
        </GridPane>

        <Separator/>

        <!-- Panel Artista (visible dinamicamente) -->
        <VBox fx:id="panelArtista" spacing="8" visible="false" managed="false">
          <Label text="DATOS DEL ARTISTA" style="-fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
          <TextField fx:id="txtApodo" promptText="Apodo profesional (opcional)"
                     prefHeight="32" maxWidth="Infinity"/>
          <Label text="Especialidades (al menos una):"/>
          <HBox spacing="16">
            <CheckBox fx:id="chkAcrobacia"    text="Acrobacia"/>
            <CheckBox fx:id="chkHumor"        text="Humor"/>
            <CheckBox fx:id="chkMagia"        text="Magia"/>
            <CheckBox fx:id="chkEquilibrismo" text="Equilibrismo"/>
            <CheckBox fx:id="chkMalabarismo"  text="Malabarismo"/>
          </HBox>
          <Separator/>
        </VBox>

        <!-- Panel Coordinacion (visible dinamicamente) -->
        <VBox fx:id="panelCoordinacion" spacing="8" visible="false" managed="false">
          <Label text="DATOS DE COORDINACION" style="-fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
          <HBox spacing="20" alignment="CENTER_LEFT">
            <CheckBox fx:id="chkSenior" text="Es Senior"/>
            <DatePicker fx:id="dpFechaSenior" promptText="Fecha desde que es Senior"
                        prefWidth="220" disable="true"/>
          </HBox>
          <Separator/>
        </VBox>

        <Label fx:id="lblMensaje" text="" style="-fx-font-size:12;" wrapText="true" maxWidth="Infinity"/>
      </VBox>
    </ScrollPane>
  </center>
  <bottom>
    <HBox alignment="CENTER_RIGHT" spacing="10">
      <padding><Insets bottom="10" right="16" top="8"/></padding>
      <Button text="Guardar cambios" onAction="#guardar"  prefWidth="150" prefHeight="34" styleClass="btnGreen"/>
      <Button text="Volver"          onAction="#volver"   prefWidth="100" prefHeight="34"/>
      <Button text="?" onAction="#mostrarAyuda" styleClass="btn-ayuda" prefWidth="34" prefHeight="34"/>
    </HBox>
  </bottom>
</BorderPane>
